# ============================================
# Variables de entorno para desarrollo
# ============================================

# API URL del backend
REACT_APP_API_URL=http://localhost:8080/api

# Activar/desactivar datos mock (true | false)
# Cuando es true, NO se necesita el backend corriendo
REACT_APP_USE_MOCK=false

# Latencia simulada para mocks (ms) - simula delay de red
REACT_APP_MOCK_DELAY=400

