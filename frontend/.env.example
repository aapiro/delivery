# --- Cliente → quarkus-backend ---
# URL base (incluye prefijo /api si el backend usa quarkus.http.root-path=/api)
REACT_APP_API_URL=http://localhost:8080/api

# --- Mock vs API real ---
# true  = datos locales (fixtures), no requiere backend
# false = consumir Quarkus (Docker / ./mvnw quarkus:dev)
REACT_APP_USE_MOCK=false

# Retardo simulado en mocks (ms)
REACT_APP_MOCK_DELAY=400
